generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model InstagramAuth {
  id             String   @id @default(cuid())
  instagramUserId String?
  username       String?
  accessTokenEnc String
  tokenType      String?
  expiresAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Draft {
  id         String   @id @default(cuid())
  caption    String
  mediaUrl   String
  previewUrl String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
